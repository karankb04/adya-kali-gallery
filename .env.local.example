# Cloudflare R2 public base URL (no trailing slash)
# e.g. https://pub-xxxxxxxxxxxx.r2.dev  OR  https://images.yourdomain.com
NEXT_PUBLIC_R2_BASE_URL=

# Google Apps Script Web App URL (the Sheet-backed JSON API).
# Deploy the script as a Web App ("Anyone" access) and paste its /exec URL here.
# If left blank, the app falls back to the bundled data/images.json.
IMAGES_API_URL=

# Canonical site URL (used for SEO: canonical tags, sitemap, structured data).
# e.g. https://adya-kali-gallery.vercel.app  OR  your custom domain
NEXT_PUBLIC_SITE_URL=
